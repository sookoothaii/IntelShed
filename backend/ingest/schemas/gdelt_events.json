{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GDELT Events",
  "description": "Fields produced by gdelt_bridge for GDELT pulse/geo records",
  "type": "object",
  "properties": {
    "id": { "type": "string", "description": "GDELT event ID" },
    "title": { "type": "string", "description": "Headline / title" },
    "snippet": { "type": "string", "description": "Article snippet / summary" },
    "seen_date": { "type": "string", "description": "Date seen (ISO 8601)" },
    "url": { "type": "string", "description": "Source URL" },
    "country": { "type": "string", "description": "Country name" },
    "place": { "type": "string", "description": "Place name" },
    "themes": { "type": "string", "description": "GDELT themes (semicolon-separated)" },
    "lat": { "type": ["number", "string"], "description": "Latitude" },
    "lon": { "type": ["number", "string"], "description": "Longitude" }
  },
  "required": ["id", "title"],
  "optional": ["snippet", "seen_date", "url", "country", "place", "themes", "lat", "lon"]
}
