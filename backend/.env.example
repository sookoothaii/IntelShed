# Copy this file to .env and fill in your own values.
# OpenSky OAuth2 client credentials — create an API client at
# https://opensky-network.org/my-opensky/account  ->  API Client
# Without these, /api/aircraft uses adsb.lol (free, global grid) automatically.
OPENSKY_CLIENT_ID=your-username-api-client
OPENSKY_CLIENT_SECRET=your_client_secret_here
# auto | opensky | adsb — force a single provider
AIRCRAFT_SOURCE=auto
# Regional ADS-B grid when OpenSky/adsb path is active: auto | adsb.fi | adsb.lol
# Use adsb.fi if adsb.lol stays empty or times out on your network.
# ADSB_PRIMARY=adsb.fi
# ADSB_TOTAL_TIMEOUT=14
# ADSB_NODE_TIMEOUT=6

# ReliefWeb v2 (humanitarian crises on globe) — request appname:
# https://apidoc.reliefweb.int/parameters#appname
# RELIEFWEB_APPNAME=your-org-worldbase-abc123

# External LLM providers (optional — used when provider != "ollama" in /api/chat)
# Get keys from: OpenAI (https://platform.openai.com), Anthropic (https://console.anthropic.com),
# Groq (https://console.groq.com), or any OpenAI-compatible endpoint
OPENAI_API_KEY=sk-...
# Optional override for OpenAI-compatible endpoints (proxy, Azure-style gateway, local vLLM)
# OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
GROQ_API_KEY=gsk_...
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# OpenRouter (unified API for many models): https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# NVIDIA NIM (OpenAI-compatible): https://build.nvidia.com/explore/discover
# Example models: stepfun-ai/step-3.7-flash (fast tool-use), qwen/qwen3.5-122b-a10b, deepseek-ai/deepseek-v4-flash
NVIDIA_API_KEY=nvapi-...
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Default chat provider/model when the HUD has no explicit selection.
# Falls back to ollama/qwen3:8b when unset. The operator can still override in the HUD.
# WORLDBASE_CHAT_PROVIDER=nvidia
# WORLDBASE_CHAT_MODEL=stepfun-ai/step-3.7-flash

# AIS data sources (optional)
# AISSTREAM_API_KEY=your-key   # aisstream.io — live WebSocket AIS (recommended for Malacca / Thailand)
# NEWSDATA_API_KEY=your-key    # newsdata.io — optional headlines (complements GDELT); https://newsdata.io/
# Live Query Preview defaults (Free plan ~12h delay):
# WORLDBASE_NEWSDATA_COUNTRIES=al,de,us,ir,th
# WORLDBASE_NEWSDATA_LANGUAGE=de,en
# WORLDBASE_NEWSDATA_CATEGORY=breaking,domestic,politics,technology,world
# WORLDBASE_NEWSDATA_EXCLUDE_DOMAIN=reflector.com   # jail-booking spam on free tier
# WORLDBASE_NEWSDATA_PRIORITYDOMAIN=low             # medium/top = fewer junk sources
# WORLDBASE_NEWSDATA_DOMAINURL=          # optional; ground.news is NOT in NewsData DB — pick from GET /api/newsdata/sources
# WORLDBASE_NEWSDATA_QUERY=              # optional extra q filter on /api/1/latest
# WORLDBASE_NEWSDATA_CACHE_SEC=900
# WORLDBASE_NEWSDATA_SOURCES_CACHE_SEC=86400
# Briefing skips sports/entertainment headlines (newsdata_bridge.is_sports_content); tourism/local economy kept
# WORLDBASE_MARITIME_AISSTREAM=1          # background WebSocket collector (default on when key set)
# WORLDBASE_MARITIME_COLLECT_SEC=30       # one-shot snapshot seconds when background collector off
# WORLDBASE_MARITIME_STREAM_STALE_SEC=1800  # drop AIS positions not seen within 30 min
# WORLDBASE_MARITIME_MAX_VESSELS=800
# WORLDBASE_MARITIME_REGIONS=malacca,laem_chabang,bangkok_port,phuket,singapore  # default when operator region is thailand; use "all" for every port in ais_bridge.py
MYSHIPTRACKING_API_KEY=your-key
AISHUB_API_KEY=your-key

# Windy.com APIs (separate keys per product — see api.windy.com)
# Webcams: DATA → WEBCAMS tab
# WINDY_WEBCAM_API_KEY=your-webcam-api-key
# Point forecast: POST /api/point-forecast/v2 (server-side only)
# WINDY_POINT_API_KEY=your-point-forecast-key
# Map overlay: libBoot.js in browser (exposed via GET /api/windy/config)
# WINDY_MAP_API_KEY=your-map-forecast-key
# WINDY_PLUGINS_API_KEY=your-plugins-key
# WORLDBASE_OPERATOR_LAT=9.55
# WORLDBASE_OPERATOR_LON=100.05
# WINDY_POINT_MODEL=gfs

# LTA DataMall (optional — data.gov.sg v1 works without key for Singapore cams)
# LTA_DATAMALL_ACCOUNT_KEY=your-account-key
# ITIC Thailand traffic cameras (application required — future connector)
# ITIC_API_TOKEN=

# Credential registry: GET /api/credentials/status (never returns secret values)

# Local LLM (Ollama) — Phase 1 default: Qwen3 8B
# ollama pull qwen3:8b && ollama pull nomic-embed-text
OLLAMA_MODEL=qwen3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
# Windows: 127.0.0.1 is more reliable than localhost (IPv6 quirks)
OLLAMA_HOST=http://127.0.0.1:11434
# VRAM tuning (RTX 3080 Ti shares GPU with Cesium Globe + optional HAK_GAL firewall)
# OLLAMA_KEEP_ALIVE=0          # unload model immediately after each request (max VRAM for Globe)
# OLLAMA_KEEP_ALIVE=1m         # default — short warm cache
# OLLAMA_CHAT_TIMEOUT=600      # seconds for /api/chat + tool rounds (local LLM can be slow)
# Autopilot: local Ollama situation briefing (feeds + fusion hotspots + alerts)
WORLDBASE_BRIEFING_AUTOPILOT=1
WORLDBASE_BRIEFING_INTERVAL=21600
# Operator home region for 24h security protocol (thailand | germany | bangkok)
WORLDBASE_OPERATOR_REGION=thailand
# Briefing language: en (default security digest) or de
WORLDBASE_BRIEFING_LANG=en
# FtM graph → 24h digest (who/what from feeds + ingest; excludes Airplane by default)
# Reserve LOCAL digest slots for GDELT media heat (default 2 of 6 LOCAL lines)
# WORLDBASE_BRIEFING_GDELT_LOCAL_SLOTS=2
# WORLDBASE_BRIEFING_NEWSDATA_SLOTS=2
# Shared feed snapshot cache for POST /api/briefing/generate (seconds, default 90)
# WORLDBASE_SNAPSHOT_CACHE_SEC=90
# Max anticipatory watch items in briefing JSON (default 5)
# WORLDBASE_BRIEFING_WATCH_MAX=5
# Track 4 — prediction ledger (watch-item outcomes, 30d hit rate in quality.meta)
# WORLDBASE_PREDICTION_LEDGER=1
# WORLDBASE_PREDICTION_WINDOW_DAYS=30
# WORLDBASE_PREDICTION_RESOLVE_INTERVAL_S=3600
# Track 3 — GraphRAG-lite (2-hop FtM subgraph in briefing prompt)
# WORLDBASE_BRIEFING_INTEL_SUBGRAPH=1
# WORLDBASE_INTEL_SUBGRAPH_HOPS=2
# WORLDBASE_INTEL_SUBGRAPH_SEED_LIMIT=30
# WORLDBASE_INTEL_SUBGRAPH_NODE_LIMIT=80
# WORLDBASE_INTEL_SPATIAL_EDGES=1          # nearby FtM links after feed ingest (Track 3+)
# WORLDBASE_INTEL_SPATIAL_MAX_KM=120
# WORLDBASE_INTEL_SPATIAL_MAX_ENTITIES=80
# WORLDBASE_INTEL_SEMANTIC_EDGES=1          # samePlace + nearEvent after feed ingest (Track 3+ Sprint 1)
# WORLDBASE_INTEL_SANCTION_EDGES=1          # vessel→sanction edges when index available
# WORLDBASE_INTEL_SEMANTIC_MAX_KM=120
# WORLDBASE_INTEL_SUBGRAPH_EXPORT=1         # write backend/data/intel_subgraph_latest.json after feed ingest
# WORLDBASE_BRIEFING_INTEL=1
# WORLDBASE_BRIEFING_INTEL_WINDOW_HOURS=24
# WORLDBASE_BRIEFING_INTEL_FETCH_LIMIT=200
# WORLDBASE_BRIEFING_INTEL_PER_BUCKET=4
# WORLDBASE_BRIEFING_INTEL_EXCLUDE_SCHEMAS=Airplane,Thing

# P8 — Dark Web / Darknet OSINT (opt-in)
# WORLDBASE_DARKWEB=1
# WORLDBASE_DARKWEB_ENGINES=ahmia,darksearch
# WORLDBASE_DARKWEB_CACHE_SEC=3600
# WORLDBASE_DARKWEB_MAX_RESULTS=50
# WORLDBASE_DARKWEB_TIMEOUT_SEC=15
# Optional Tor SOCKS5 proxy for .onion engines (Torch, Tor66, OnionLand, TorDex, Haystak, Not Evil)
# WORLDBASE_DARKWEB_TOR_PROXY=socks5://127.0.0.1:9050
# WORLDBASE_BRIEFING_DARKWEB=1

# K3 — Telegram SOCMINT Bridge (opt-in)
# Public-channel scanner via Telethon. Needs a Telegram API id/hash from
# https://my.telegram.org/auth (under "API development tools"). A pre-authorized
# TELEGRAM_SESSION_STRING is recommended for headless servers; interactive phone
# login is not suitable for a service.
# WORLDBASE_TELEGRAM=1
# TELEGRAM_API_ID=1234567
# TELEGRAM_API_HASH=your-api-hash
# TELEGRAM_SESSION_STRING=your-string-session
# TELEGRAM_PHONE=+491234567890
# WORLDBASE_TELEGRAM_CHANNELS=bkkbangkoknews,frontiermyanmar,thairath
# WORLDBASE_TELEGRAM_POST_LIMIT=50
# WORLDBASE_TELEGRAM_CACHE_SEC=600
# WORLDBASE_TELEGRAM_RETENTION_DAYS=90
# WORLDBASE_BRIEFING_TELEGRAM=1

# P9 — Identity OSINT Bridge (opt-in)
# Passive email/username existence checks across 50+ social platforms.
# No credential stuffing, no profile scraping — only HTTP status checks.
# Results linked to FtM Person entities via UserAccount + owns edge.
# WORLDBASE_IDENTITY_OSINT=1
# WORLDBASE_IDENTITY_OSINT_RATE_LIMIT_SEC=2
# WORLDBASE_IDENTITY_OSINT_MAX_PLATFORMS=50
# WORLDBASE_IDENTITY_OSINT_CACHE_SEC=86400
# WORLDBASE_BRIEFING_IDENTITY=1

# K4 — Satellite Imagery Change Detection (default on; requires rasterio + GDAL wheels)
# WORLDBASE_SATELLITE_CHANGE=1

# WorldBase self URL (briefing autopilot + River anomaly scanner)
WORLDBASE_SELF=http://localhost:8002
# GDELT: min seconds between DOC/GEO requests (API ~5s limit); adaptive backoff on 429
# WORLDBASE_GDELT_MIN_INTERVAL=5.5
# WORLDBASE_GDELT_BACKOFF_SEC=45
# WORLDBASE_GDELT_BACKOFF_MAX_SEC=300
# WORLDBASE_GDELT_LOCAL_RETRIES=2
# WORLDBASE_GDELT_LOCAL_RETRY_MAX_SEC=20
# WORLDBASE_GDELT_CACHE_LOCAL_SEC=600
# WORLDBASE_GDELT_CACHE_GLOBAL_SEC=900
# WORLDBASE_GDELT_HTTP_LOCAL_SEC=20
# WORLDBASE_GDELT_HTTP_GLOBAL_SEC=30
# WORLDBASE_GDELT_COLD_START_SEC=18
# Local DOC pulse: only last 24h headlines; drop stale Songkran/tourism promos from briefing
# WORLDBASE_GDELT_LOCAL_TIMESPAN=24h
# WORLDBASE_GDELT_LOCAL_MAX_AGE_H=24
# Background RAG indexing (GDELT pulse, hazards, situations) — set 0 to reduce GDELT traffic
# WORLDBASE_RAG_AUTOPILOT=1
# Hybrid RAG search tuning (sqlite-vec + FTS5 RRF in rag_memory.py)
# RAG_TOP_K=6
# RAG_RRF_K=60
# RAG_HYBRID_CANDIDATES=24
# BGE reranker after RRF — CPU/i9 preferred (0 VRAM); requires: pip install sentence-transformers onnxruntime optimum
# RAG_RERANK=1
# RAG_RERANK_MODEL=BAAI/bge-reranker-base
# RAG_RERANK_DEVICE=cpu
# RAG_RERANK_POOL=24
# I7 — ONNX int8 quantization backend (cold start ~5s vs ~60s for Torch)
# RAG_RERANK_BACKEND=auto          # auto | onnx | torch
# RAG_RERANK_WARMUP=1              # preload model during startup
# RAG_RERANK_ONNX_DIR=data/models/reranker_onnx
# RAG ingest: news (GDELT local/global + NewsData) + prediction watches run on WORLDBASE_RAG_AUTOPILOT=1
# Feed ingest -> RAG uses YAML chunk profiles in ingest/mappings/*.yml (Track R1.3)
# RAG_FEED_INGEST=1
# Track R1.4 — briefing agentic loop (coverage → retrieve → corroboration)
# BRIEFING_AGENTIC_LOOP=1
# Track R1 — spatial + CRAG-lite chat
# RAG_SPATIAL=1
# RAG_GEOHASH_PRECISION=6
# RAG_CRAG=1
# RAG_CRAG_MIN_SCORE=0.35

# Feed drift (trust panel) — SQL snapshots on feed_cache; freshness in GET /api/trust
# WORLDBASE_FEED_DRIFT_RATIO=0.1
# WORLDBASE_FEED_DRIFT_WATCH=gdacs_v3,quakes:day,cve,wildfires,outages,pegel,energy_de,hazards

# Fusion grid snapshots (Track 5) — separate from feed_drift connector baselines
# WORLDBASE_FUSION_SNAPSHOT_INTERVAL_S=21600
# WORLDBASE_FUSION_COMPARE_TOLERANCE_H=3
# WORLDBASE_FUSION_SNAPSHOT_RETAIN_D=14

# Thailand briefing enrichment (no API keys)
# WORLDBASE_CAMS_CACHE_SEC=3600
# WORLDBASE_HDX_CACHE_SEC=3600

# Optional: Have I Been Pwned API v3 key for /api/osint/email breach names (free tier at haveibeenpwned.com/API/Key)
# HIBP_API_KEY=

# Cloudflare Radar traffic anomalies (free API token — optional, enhances /api/outages)
# https://dash.cloudflare.com/profile/api-tokens → Radar Read
# CLOUDFLARE_API_TOKEN=

# Offline PMTiles — Thailand + world stack (see scripts/download-pmtiles.ps1)
# .\scripts\download-pmtiles.ps1 -Region stack
# .\scripts\start-pmtiles-serve.ps1
# PMTILES_SERVE_URL=http://127.0.0.1:8088
# PMTILES_PATH=D:/MCP Mods/worldbase/data/pmtiles/thailand.pmtiles

# DuckDB fusion — optional local GeoParquet (Overture/STAC export)
# FUSION_GEOPARQUET=D:/data/overture-buildings.parquet
# FUSION_DUCKDB_PATH=D:/data/fusion.duckdb
# GeoParquet staging from feed_cache (H3 index via DuckDB spatial):
# FUSION_STAGE_PARQUET=backend/data/fusion_events.parquet
# FUSION_H3_RES=5

# Intelligence layer (FollowTheMoney canonical entity store on DuckDB)
# WORLDBASE_FTM_DB_PATH=D:/MCP Mods/worldbase/backend/data/entities.duckdb
# Feed-cache prune: drop abandoned feed_cache keys older than this (seconds, default 7 days)
# WORLDBASE_FEED_CACHE_MAX_AGE_SEC=604800
# DuckDB Write-Through Queue (I1): serializes all DuckDB writes via SQLite WAL + retry + DLQ
# WORLDBASE_DUCKDB_QUEUE=0           # 1 = enable write queue (default off, zero overhead when off)
# Dynamic Feature Flags (J2): SQLite-backed toggle without restart; env vars remain defaults
# WORLDBASE_ADMIN_FLAGS=1            # 1 = enable runtime flag overrides (default on)
# WORLDBASE_FLAG_OVERRIDE=env        # force env-only mode (ignore SQLite overrides)
# Frontend crash telemetry (J3): POST /api/telemetry/frontend-error — always on, no env var needed

# Document intel ingest (GLiNER NER -> FtM graph; optional GLiREL relations).
# PC-only, GPU-accelerated; the Pi never loads this. See requirements.txt and
# THIRD_PARTY_NOTICES.md. GLiREL (CC BY-NC-SA) is OFF by default for OSS safety.
# WORLDBASE_INTEL_GLIREL=0          # 1 = opt in to semantic relations (non-commercial license)
# WORLDBASE_INTEL_DEVICE=auto          # auto | cuda | cpu
# WORLDBASE_GLINER_MODEL=urchade/gliner_multi-v2.1
# WORLDBASE_GLIREL_MODEL=jackboyla/glirel-large-v0
# WORLDBASE_GLINER_THRESHOLD=0.45      # entity confidence cutoff
# WORLDBASE_GLIREL_THRESHOLD=0.50      # relation confidence cutoff (raise for fewer false edges)
# WORLDBASE_INTEL_MAX_CHARS=60000      # per-request text cap
# WORLDBASE_INTEL_CHUNK_CHARS=1400     # chunk window fed to the models
#
# Entity resolution (Splink -> sameAs edges; pip install "splink>=4.0,<5")
# WORLDBASE_ENTITY_RESOLUTION_AUTOPILOT=0   # 1 = nightly run (default off)
# WORLDBASE_ENTITY_RESOLUTION_AFTER_FEEDS=0  # 1 = run RESOLVE after each SYNC FEEDS / feed autopilot
# WORLDBASE_ENTITY_RESOLUTION_SPLINK=0        # 1 = enable fuzzy Splink stage (default off; subset+exact only)
# WORLDBASE_ENTITY_RESOLUTION_INTERVAL=86400
# WORLDBASE_ENTITY_RESOLUTION_THRESHOLD=0.85
# WORLDBASE_ENTITY_RESOLUTION_LIMIT=3000    # max entities per schema per run
#
# Live feed -> FtM ingest (T2 YAML mappings; runs in phase1 loop when autopilot on)
# WORLDBASE_FEED_INGEST_AUTOPILOT=1         # default on — every WORLDBASE_FEED_INGEST_INTERVAL
# WORLDBASE_FEED_INGEST_INTERVAL=600

# Pi <-> PC sync security (REQUIRED if backend is reachable on LAN)
# Generate: .\scripts\setup-node-security.ps1
# Rate limiting — shared counters for Pi ingest/pull when API runs multi-worker or restarts
# Local Redis (recommended): .\scripts\start-redis.ps1  then redis://127.0.0.1:6380/0
# (6380 — host 6379 may be used by other stacks e.g. flowsint)
RATE_LIMIT_STORAGE=redis
RATE_LIMIT_REDIS_URL=redis://127.0.0.1:6380/0
RATE_LIMIT_KEY_PREFIX=worldbase:ratelimit
RATE_LIMIT_REDIS_CONNECT_TIMEOUT=2
RATE_LIMIT_REDIS_SOCKET_TIMEOUT=2
RATE_LIMIT_REDIS_MAX_CONNECTIONS=10
# RATE_LIMIT_NODE_INGEST=100/minute
# RATE_LIMIT_NODE_PULL=20/minute
# RATE_LIMIT_NODE_COMMAND=10/minute
# RATE_LIMIT_GENERAL=1000/hour

NODE_INGEST_TOKEN=
NODE_ADMIN_TOKEN=
# Backend bind: 127.0.0.1 = PC only; 0.0.0.0 = LAN (use with tokens above).
# In Docker the backend always binds 0.0.0.0 inside its container and is only
# reachable on the LAN through the Caddy TLS proxy.
WORLDBASE_BIND_HOST=127.0.0.1
# MCP read tools for Cursor (Streamable HTTP at /api/mcp). Set 0 to disable mount.
WORLDBASE_MCP=1
# MCP write tools (briefing generate). Set 0 for read-only MCP.
WORLDBASE_MCP_WRITE=1
# Agent Bus: MCP/API globe fly_to + layer toggle → open HUD (:5176). Default off.
WORLDBASE_AGENT_BUS=0
# P3+ — Multi-Agent Orchestrator (rule-based, 0 VRAM). Requires WORLDBASE_AGENT_BUS=1 for HUD phase updates.
# WORLDBASE_AGENT_ORCHESTRATOR=1
# WORLDBASE_AGENT_ORCHESTRATOR_MAX_WORKERS=8
# WORLDBASE_AGENT_ORCHESTRATOR_PHASE_TIMEOUT=10.0
# WORLDBASE_AGENT_ORCHESTRATOR_CIRCUIT_BREAKER_THRESHOLD=3
# WORLDBASE_AGENT_ORCHESTRATOR_CIRCUIT_BREAKER_WINDOW=60
# Optional API key: required for /api/chat and MCP when set. Same value in frontend/.env as VITE_WORLDBASE_API_KEY for HUD chat.
# Briefing + intel ingest stay open on 127.0.0.1 bind; LAN bind (0.0.0.0) requires key or NODE_INGEST_TOKEN.
# WORLDBASE_API_KEY=
# Max bytes for POST /api/intel/ingest/document (default 10485760).
# WORLDBASE_INTEL_UPLOAD_MAX_BYTES=10485760
# Secure-by-default for LAN/Docker: 1 = refuse to start without NODE_INGEST_TOKEN.
WORLDBASE_REQUIRE_NODE_TOKEN=
# Persistent SQLite path (Docker sets /data/worldbase.db on a named volume).
# WORLDBASE_DB_PATH=

# PostgreSQL Configuration (optional - for production/scaling)
# Set DATABASE_URL to use PostgreSQL instead of SQLite
# Format: postgresql+asyncpg://user:password@host:port/database
# DATABASE_URL=postgresql+asyncpg://worldbase:worldbase@localhost:5432/worldbase

# PostgreSQL connection pool settings
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# SQLALCHEMY_ECHO=false
# Extra browser origins allowed by CORS (comma-separated), e.g. https://192.168.1.111
WORLDBASE_CORS_ORIGINS=

# LLM security — WorldBase slim guard (baseline, 0 VRAM) + optional HAK_GAL spare-parts HTTP
# WORLDBASE_SLIM_GUARD=1
# WORLDBASE_SLIM_GUARD_MCP=1
# FIREWALL_HOST=localhost:8001                # optional; full HAK_GAL stack ~16 GB VRAM — lean only
# WORLDBASE_FIREWALL_RISK_THRESHOLD=0.7
# WORLDBASE_FIREWALL_USER_ID=operator
# WORLDBASE_FIREWALL_TRACE=0
# WORLDBASE_FIREWALL_FAIL_CLOSED=0
# WORLDBASE_FIREWALL_MCP=0                    # 1 = optional HAK_GAL scan on MCP writes
# WORLDBASE_FIREWALL_MCP_FAIL_CLOSED=0        # 1 = block MCP when HAK_GAL down (default fail-open)
# WORLDBASE_FIREWALL_SHADOW=0

# Flowsint Docker stack (scripts/start-flowsint.ps1)
FLOWSINT_URL=http://127.0.0.1:5173
FLOWSINT_API_URL=http://127.0.0.1:5001

# NASA FIRMS wildfire hotspots (free MAP_KEY): https://firms.modaps.eosdis.nasa.gov/api/map_key
# Without this, /api/wildfires falls back to NASA EONET open fire events.
# FIRMS_MAP_KEY=your-map-key-here

# ENTSO-E Transparency — EU electricity prices + generation (/api/eu-energy, energy DE globe)
# Free Web API security token: https://transparency.entsoe.eu/ -> Account -> Web API Security Token
# Without this, /api/energy/de/globe returns demo_mode data.
# ENTSOE_SECURITY_TOKEN=your-entsoe-security-token

# Blitzortung lightning (station operator account — public API retired)
# BLITZORTUNG_USER=your-blitzortung-username
# BLITZORTUNG_PASSWORD=your-blitzortung-password

# GTFS-Realtime (public transit on globe) — Berlin has dedicated VBB feed
# Hamburg/Munich default to gtfs.de aggregate (bbox-filtered per city)
GTFS_BERLIN_URL=https://production.gtfsrt.vbb.de/data
# GTFS_HAMBURG_URL=https://realtime.gtfs.de/realtime-free.pb
# GTFS_MUNICH_URL=https://realtime.gtfs.de/realtime-free.pb
# GTFS_DE_AGGREGATE_URL=https://realtime.gtfs.de/realtime-free.pb

# I4 — Observability: Prometheus metrics + OpenTelemetry tracing + Webhook alerting
# Prometheus exposition: GET /api/metrics (16 gauges + 1 histogram)
# WORLDBASE_METRICS=1                   # default on
# OpenTelemetry tracing (opt-in, requires opentelemetry-instrumentation-fastapi)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# WORLDBASE_OTEL=1                      # default off
# OTEL_SERVICE_NAME=worldbase-api
# Webhook alerting (Discord/Slack/Telegram compatible JSON POST)
# WORLDBASE_ALERT_WEBHOOK=https://discord.com/api/webhooks/...
# WORLDBASE_ALERT_DEDUP_S=900           # 15 min dedup window per condition

# J5 — API Quota & Cost Monitor
# GET /api/quota — per-source daily usage, limits, cost, 7-day trend
# WORLDBASE_QUOTA_MONITOR=1              # default on
# WORLDBASE_QUOTA_ALERT_THRESHOLD=0.8    # alert at 80% of daily limit
# Per-source daily limits (0 = unlimited):
# WORLDBASE_QUOTA_LIMIT_AISSTREAM=5000
# WORLDBASE_QUOTA_LIMIT_NEWSDATA=200
# WORLDBASE_QUOTA_LIMIT_OPENSKY=4000
# WORLDBASE_QUOTA_LIMIT_GDELT=10000

# J7 — Prompt Injection Defense (3-Layer)
# Layer 0: prompt_guard.py — always on when WORLDBASE_SLIM_GUARD=1
# Layer 1: rag_integrity.py — always on (scans RAG context before LLM injection)
# Layer 2: session_guard.py — SQLite-persisted multi-turn attack detection
# WORLDBASE_SESSION_GUARD=1                # default on
# Layer 3: output_guard.py — post-LLM leak prevention (system prompt, secrets, tags)
# WORLDBASE_OUTPUT_GUARD=1                 # default on

# J8 — YAML Mapping Schema Drift Detection
# POST /api/intel/feeds/validate — validates YAML mappings against JSON schemas
# WORLDBASE_MAPPING_VALIDATOR=1            # default on

# I6 — Tiered Storage: Feed Cache TTL + Auto-VACUUM + FtM Parquet Archival
# Feed cache entries older than TTL auto-deleted (runs in briefing autopilot)
# WORLDBASE_FEED_CACHE_TTL=604800          # 7d in seconds (default)
# FtM entities with zero edges older than archive_days → Parquet → deleted from DuckDB
# WORLDBASE_FTM_ARCHIVE_DAYS=0             # default off, set to 90 to enable
# WORLDBASE_ARCHIVE_DIR=data/archive       # default: ../data/archive relative to backend/
# API: POST /api/intel/archive/run?dry_run=true — trigger archival
# API: POST /api/intel/archive/reload?month=2026-06 — reload archived entities
# API: GET /api/intel/archive/stats — archive directory stats
# Health: GET /api/health reports duckdb_size_mb + archive stats

# I9 — RBAC + JWT + API Key Scopes + Rotation
# POST /api/auth/token — exchange API key for JWT (15min access + 7d refresh)
# POST /api/auth/refresh — refresh access token
# POST /api/auth/rotate — rotate API key (old key valid 24h grace period)
# GET /api/auth/scopes — current key scope configuration
# WORLDBASE_RBAC=0                          # default off, opt-in
# WORLDBASE_JWT_SECRET=                     # auto-generated if missing (persisted to .env)
# WORLDBASE_JWT_ACCESS_TTL=900              # 15 min
# WORLDBASE_JWT_REFRESH_TTL=604800          # 7 days
# WORLDBASE_KEY_GRACE_PERIOD=86400          # 24h grace for rotated keys

# I10 — WebSocket Gateway + Frontend State Persistence
# GET /api/ws — bidirectional WebSocket for real-time globe updates
# Server pushes: AIS deltas, feed events, briefing ready, agent actions
# Client sends: viewport bbox, layer subscriptions, ping
# WORLDBASE_WEBSOCKET=0                    # default off, opt-in
# Frontend: VITE_WORLDBASE_WS=1            # enable WS client in frontend
# VITE_WORLDBASE_WS_PORT=8002              # WS port (default: API port)

# J1 — Prompt Versioning & A/B Testing Framework
# SQLite-backed prompt registry with version history + A/B experiments
# API: GET /api/admin/prompts — list all prompt versions
# API: POST /api/admin/prompts — save new prompt version
# API: POST /api/admin/prompts/{id}/activate — activate a prompt version (instant, no restart)
# API: GET /api/admin/prompts/experiments — list A/B experiments
# API: POST /api/admin/prompts/experiments — create A/B experiment
# API: POST /api/admin/prompts/experiments/{name}/evaluate — run Mann-Whitney U test
# API: GET /api/admin/prompts/experiments/{name}/results — get quality scores
# WORLDBASE_PROMPT_REGISTRY=0              # default off, opt-in

# J4 — Data Lineage & Impact Graph
# Tracks feed→entity→briefing→insight→watch_item dependencies in SQLite
# API: GET /api/intel/impact?entity_id=... — downstream impact for an entity
# API: POST /api/admin/refresh/{source_id}?source_type=entity — cascade refresh
# API: GET /api/admin/lineage/stats — lineage table statistics
# API: GET /api/admin/lineage/downstream/{source_id} — direct downstream edges
# API: GET /api/admin/lineage/upstream/{target_id} — direct upstream edges
# WORLDBASE_LINEAGE=0                      # default off, opt-in (adds write overhead to ingest)

# P5 — FtM 4.0 StatementEntity (per-value provenance)
# DuckDB `statements` table already populated by ftm_store.upsert() — these env vars control query API access
# API: GET /api/intel/statements?entity_id=... — per-value statements for an entity
# API: GET /api/intel/statements/provenance?dataset=...&prop=... — query by source dataset
# API: GET /api/intel/statements/stats — statement table statistics
# WORLDBASE_FTM_STATEMENTS=0               # default off, opt-in

# P5+ — Dynamic Knowledge Graph (agent writes back)
# External edges: user/agent-derived hypotheses with confidence cap
# API: GET /api/intel/edges/external?confirmed=false — list pending external edges
# API: POST /api/intel/edges/approve?source_id=...&target_id=...&kind=...&dataset=...
# API: POST /api/intel/edges/reject?source_id=...&target_id=...&kind=...&dataset=...
# API: GET /api/intel/edges/review/stats — edge review statistics
# WORLDBASE_DYNAMIC_GRAPH=0               # default off, opt-in
# WORLDBASE_DYNAMIC_GRAPH_MAX_CONFIDENCE=0.7  # cap for external edges (human-confirmed = 0.9)

# P7 — Maritime Pattern-of-Life (AIS Anomaly Detection)
# Stores AIS positions in SQLite (not DuckDB — avoids lock contention)
# Rolling 24h window features: speed variance, night port visits, AIS gaps, risk zone proximity, course changes
# Rule-based weighted anomaly score (0.0-1.0), >threshold = anomaly alert
# Risk zones: Sumatra Piracy, South China Sea, Bab-el-Mandeb, Gulf of Aden, Malacca Strait
# Ports: Singapore, Laem Chabang, Bangkok, Phuket, Penang, Port Klang
# API: GET /api/maritime/anomalies — flagged vessels with feature breakdown
# API: GET /api/maritime/trajectory/{mmsi} — features for specific vessel
# API: GET /api/maritime/trajectory/stats — trajectory tracking statistics
# WORLDBASE_MARITIME_TRAJECTORY=0            # default off, opt-in
# WORLDBASE_MARITIME_ANOMALY_THRESHOLD=0.6   # anomaly score threshold (0.0-1.0)
# WORLDBASE_MARITIME_TRAJECTORY_RETENTION_H=24  # position retention in hours

# P6 — Spatial Reasoning Layer (NL → Spatial Operation)
# Rule-based NL parser for geospatial queries (0 VRAM, no NLP model, no Shapely required)
# Parses: within, near, downstream, border, contains, visible_from
# Composition: AND (intersect), OR (union), THEN (sequential) — SpaRAGraph-inspired
# Static data: data/geography.json (cities, rivers, borders, regions)
# API: GET /api/intel/spatial/query?q=within 50km of Bangkok
# API: GET /api/intel/spatial/reasoning/stats — spatial reasoning statistics
# API: GET /api/intel/spatial/composition — SpaRAGraph composition matrix
# WORLDBASE_SPATIAL_REASONING=0              # default off, opt-in
# WORLDBASE_SPATIAL_NEAR_DEFAULT_KM=25       # default radius for "near" queries
