# Copy this file to .env and fill in your own values.
# OpenSky OAuth2 client credentials — create an API client at
# https://opensky-network.org/my-opensky/account  ->  API Client
# Without these, /api/aircraft uses adsb.lol (free, global grid) automatically.
OPENSKY_CLIENT_ID=your-username-api-client
OPENSKY_CLIENT_SECRET=your_client_secret_here
# auto | opensky | adsb — force a single provider
AIRCRAFT_SOURCE=auto
# Regional ADS-B grid when OpenSky/adsb path is active: auto | adsb.fi | adsb.lol
# Use adsb.fi if adsb.lol stays empty or times out on your network.
# ADSB_PRIMARY=adsb.fi
# ADSB_TOTAL_TIMEOUT=14
# ADSB_NODE_TIMEOUT=6

# ReliefWeb v2 (humanitarian crises on globe) — request appname:
# https://apidoc.reliefweb.int/parameters#appname
# RELIEFWEB_APPNAME=your-org-worldbase-abc123

# External LLM providers (optional — used when provider != "ollama" in /api/chat)
# Get keys from: OpenAI (https://platform.openai.com), Anthropic (https://console.anthropic.com),
# Groq (https://console.groq.com), or any OpenAI-compatible endpoint
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
# OpenRouter (unified API for many models): https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# AIS data sources (optional)
# AISSTREAM_API_KEY=your-key   # aisstream.io — live WebSocket AIS (recommended for Malacca / Thailand)
# WORLDBASE_MARITIME_AISSTREAM=1          # background WebSocket collector (default on when key set)
# WORLDBASE_MARITIME_COLLECT_SEC=30       # one-shot snapshot seconds when background collector off
# WORLDBASE_MARITIME_STREAM_STALE_SEC=1800  # drop AIS positions not seen within 30 min
# WORLDBASE_MARITIME_MAX_VESSELS=800
# WORLDBASE_MARITIME_REGIONS=malacca,laem_chabang,bangkok_port,phuket,singapore  # default when operator region is thailand; use "all" for every port in ais_bridge.py
MYSHIPTRACKING_API_KEY=your-key
AISHUB_API_KEY=your-key

# Windy.com APIs (separate keys per product — see api.windy.com)
# Webcams: DATA → WEBCAMS tab
# WINDY_WEBCAM_API_KEY=your-webcam-api-key
# Point forecast: POST /api/point-forecast/v2 (server-side only)
# WINDY_POINT_API_KEY=your-point-forecast-key
# Map overlay: libBoot.js in browser (exposed via GET /api/windy/config)
# WINDY_MAP_API_KEY=your-map-forecast-key
# WINDY_PLUGINS_API_KEY=your-plugins-key
# WORLDBASE_OPERATOR_LAT=9.55
# WORLDBASE_OPERATOR_LON=100.05
# WINDY_POINT_MODEL=gfs

# LTA DataMall (optional — data.gov.sg v1 works without key for Singapore cams)
# LTA_DATAMALL_ACCOUNT_KEY=your-account-key
# ITIC Thailand traffic cameras (application required — future connector)
# ITIC_API_TOKEN=

# Credential registry: GET /api/credentials/status (never returns secret values)

# Local LLM (Ollama) — Phase 1 default: Qwen3 8B
# ollama pull qwen3:8b && ollama pull nomic-embed-text
OLLAMA_MODEL=qwen3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
# Windows: 127.0.0.1 is more reliable than localhost (IPv6 quirks)
OLLAMA_HOST=http://127.0.0.1:11434
# VRAM tuning (RTX 3080 Ti shares GPU with Cesium Globe + optional HAK_GAL firewall)
# OLLAMA_KEEP_ALIVE=0          # unload model immediately after each request (max VRAM for Globe)
# OLLAMA_KEEP_ALIVE=1m         # default — short warm cache
# OLLAMA_CHAT_TIMEOUT=600      # seconds for /api/chat + tool rounds (local LLM can be slow)
# Autopilot: local Ollama situation briefing (feeds + fusion hotspots + alerts)
WORLDBASE_BRIEFING_AUTOPILOT=1
WORLDBASE_BRIEFING_INTERVAL=21600
# Operator home region for 24h security protocol (thailand | germany | bangkok)
WORLDBASE_OPERATOR_REGION=thailand
# Briefing language: en (default security digest) or de
WORLDBASE_BRIEFING_LANG=en
# FtM graph → 24h digest (who/what from feeds + ingest; excludes Airplane by default)
# Reserve LOCAL digest slots for GDELT media heat (default 2 of 6 LOCAL lines)
# WORLDBASE_BRIEFING_GDELT_LOCAL_SLOTS=2
# Shared feed snapshot cache for POST /api/briefing/generate (seconds, default 90)
# WORLDBASE_SNAPSHOT_CACHE_SEC=90
# Max anticipatory watch items in briefing JSON (default 5)
# WORLDBASE_BRIEFING_WATCH_MAX=5
# Track 4 — prediction ledger (watch-item outcomes, 30d hit rate in quality.meta)
# WORLDBASE_PREDICTION_LEDGER=1
# WORLDBASE_PREDICTION_WINDOW_DAYS=30
# WORLDBASE_PREDICTION_RESOLVE_INTERVAL_S=3600
# Track 3 — GraphRAG-lite (2-hop FtM subgraph in briefing prompt)
# WORLDBASE_BRIEFING_INTEL_SUBGRAPH=1
# WORLDBASE_INTEL_SUBGRAPH_HOPS=2
# WORLDBASE_INTEL_SUBGRAPH_SEED_LIMIT=30
# WORLDBASE_INTEL_SUBGRAPH_NODE_LIMIT=80
# WORLDBASE_BRIEFING_INTEL=1
# WORLDBASE_BRIEFING_INTEL_WINDOW_HOURS=24
# WORLDBASE_BRIEFING_INTEL_FETCH_LIMIT=200
# WORLDBASE_BRIEFING_INTEL_PER_BUCKET=4
# WORLDBASE_BRIEFING_INTEL_EXCLUDE_SCHEMAS=Airplane,Thing
# FIREWALL_HOST=localhost:8001   # empty = firewall off in UI (saves GPU); see LLM_HANDOFF.md

# WorldBase self URL (briefing autopilot + River anomaly scanner)
WORLDBASE_SELF=http://localhost:8002
# GDELT: min seconds between DOC/GEO requests (API ~5s limit); adaptive backoff on 429
# WORLDBASE_GDELT_MIN_INTERVAL=5.5
# WORLDBASE_GDELT_BACKOFF_SEC=45
# WORLDBASE_GDELT_BACKOFF_MAX_SEC=300
# WORLDBASE_GDELT_LOCAL_RETRIES=2
# WORLDBASE_GDELT_LOCAL_RETRY_MAX_SEC=20
# WORLDBASE_GDELT_CACHE_LOCAL_SEC=600
# WORLDBASE_GDELT_CACHE_GLOBAL_SEC=900
# WORLDBASE_GDELT_HTTP_LOCAL_SEC=20
# WORLDBASE_GDELT_HTTP_GLOBAL_SEC=30
# WORLDBASE_GDELT_COLD_START_SEC=18
# Background RAG indexing (GDELT pulse, hazards, situations) — set 0 to reduce GDELT traffic
# WORLDBASE_RAG_AUTOPILOT=1

# Feed drift (trust panel) — SQL snapshots on feed_cache; freshness in GET /api/trust
# WORLDBASE_FEED_DRIFT_RATIO=0.1
# WORLDBASE_FEED_DRIFT_WATCH=gdacs_v3,quakes:day,cve,wildfires,outages,pegel,energy_de,hazards

# Fusion grid snapshots (Track 5) — separate from feed_drift connector baselines
# WORLDBASE_FUSION_SNAPSHOT_INTERVAL_S=21600
# WORLDBASE_FUSION_COMPARE_TOLERANCE_H=3
# WORLDBASE_FUSION_SNAPSHOT_RETAIN_D=14

# Thailand briefing enrichment (no API keys)
# WORLDBASE_CAMS_CACHE_SEC=3600
# WORLDBASE_HDX_CACHE_SEC=3600

# Cloudflare Radar traffic anomalies (free API token — optional, enhances /api/outages)
# https://dash.cloudflare.com/profile/api-tokens → Radar Read
# CLOUDFLARE_API_TOKEN=

# Offline PMTiles — Thailand + world stack (see scripts/download-pmtiles.ps1)
# .\scripts\download-pmtiles.ps1 -Region stack
# .\scripts\start-pmtiles-serve.ps1
# PMTILES_SERVE_URL=http://127.0.0.1:8088
# PMTILES_PATH=D:/MCP Mods/worldbase/data/pmtiles/thailand.pmtiles

# DuckDB fusion — optional local GeoParquet (Overture/STAC export)
# FUSION_GEOPARQUET=D:/data/overture-buildings.parquet
# FUSION_DUCKDB_PATH=D:/data/fusion.duckdb

# Intelligence layer (FollowTheMoney canonical entity store on DuckDB)
# WORLDBASE_FTM_DB_PATH=D:/MCP Mods/worldbase/backend/data/entities.duckdb
# Feed-cache prune: drop abandoned feed_cache keys older than this (seconds, default 7 days)
# WORLDBASE_FEED_CACHE_MAX_AGE_SEC=604800

# Document intel ingest (GLiNER NER -> FtM graph; optional GLiREL relations).
# PC-only, GPU-accelerated; the Pi never loads this. See requirements.txt and
# THIRD_PARTY_NOTICES.md. GLiREL (CC BY-NC-SA) is OFF by default for OSS safety.
# WORLDBASE_INTEL_GLIREL=0          # 1 = opt in to semantic relations (non-commercial license)
# WORLDBASE_INTEL_DEVICE=auto          # auto | cuda | cpu
# WORLDBASE_GLINER_MODEL=urchade/gliner_multi-v2.1
# WORLDBASE_GLIREL_MODEL=jackboyla/glirel-large-v0
# WORLDBASE_GLINER_THRESHOLD=0.45      # entity confidence cutoff
# WORLDBASE_GLIREL_THRESHOLD=0.50      # relation confidence cutoff (raise for fewer false edges)
# WORLDBASE_INTEL_MAX_CHARS=60000      # per-request text cap
# WORLDBASE_INTEL_CHUNK_CHARS=1400     # chunk window fed to the models
#
# Entity resolution (Splink -> sameAs edges; pip install "splink>=4.0,<5")
# WORLDBASE_ENTITY_RESOLUTION_AUTOPILOT=0   # 1 = nightly run (default off)
# WORLDBASE_ENTITY_RESOLUTION_AFTER_FEEDS=0  # 1 = run RESOLVE after each SYNC FEEDS / feed autopilot
# WORLDBASE_ENTITY_RESOLUTION_SPLINK=0        # 1 = enable fuzzy Splink stage (default off; subset+exact only)
# WORLDBASE_ENTITY_RESOLUTION_INTERVAL=86400
# WORLDBASE_ENTITY_RESOLUTION_THRESHOLD=0.85
# WORLDBASE_ENTITY_RESOLUTION_LIMIT=3000    # max entities per schema per run
#
# Live feed -> FtM ingest (T2 YAML mappings; runs in phase1 loop when autopilot on)
# WORLDBASE_FEED_INGEST_AUTOPILOT=1         # default on — every WORLDBASE_FEED_INGEST_INTERVAL
# WORLDBASE_FEED_INGEST_INTERVAL=600

# Pi <-> PC sync security (REQUIRED if backend is reachable on LAN)
# Generate: .\scripts\setup-node-security.ps1
NODE_INGEST_TOKEN=
NODE_ADMIN_TOKEN=
# Backend bind: 127.0.0.1 = PC only; 0.0.0.0 = LAN (use with tokens above).
# In Docker the backend always binds 0.0.0.0 inside its container and is only
# reachable on the LAN through the Caddy TLS proxy.
WORLDBASE_BIND_HOST=127.0.0.1
# MCP read tools for Cursor (Streamable HTTP at /api/mcp). Set 0 to disable mount.
WORLDBASE_MCP=1
# MCP write tools (briefing generate). Set 0 for read-only MCP.
WORLDBASE_MCP_WRITE=1
# Agent Bus: MCP/API globe fly_to + layer toggle → open HUD (:5176). Default off.
WORLDBASE_AGENT_BUS=0
# Optional API key: required for /api/chat and MCP when set. Same value in frontend/.env as VITE_WORLDBASE_API_KEY for HUD chat.
# WORLDBASE_API_KEY=
# Secure-by-default for LAN/Docker: 1 = refuse to start without NODE_INGEST_TOKEN.
WORLDBASE_REQUIRE_NODE_TOKEN=
# Persistent SQLite path (Docker sets /data/worldbase.db on a named volume).
# WORLDBASE_DB_PATH=

# PostgreSQL Configuration (optional - for production/scaling)
# Set DATABASE_URL to use PostgreSQL instead of SQLite
# Format: postgresql+asyncpg://user:password@host:port/database
# DATABASE_URL=postgresql+asyncpg://worldbase:worldbase@localhost:5432/worldbase

# PostgreSQL connection pool settings
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# SQLALCHEMY_ECHO=false
# Extra browser origins allowed by CORS (comma-separated), e.g. https://192.168.1.111
WORLDBASE_CORS_ORIGINS=

# LLM-Security-Firewall integration (optional)
FIREWALL_HOST=localhost:8001

# Flowsint Docker stack (scripts/start-flowsint.ps1)
FLOWSINT_URL=http://127.0.0.1:5173
FLOWSINT_API_URL=http://127.0.0.1:5001

# NASA FIRMS wildfire hotspots (free MAP_KEY): https://firms.modaps.eosdis.nasa.gov/api/map_key
# Without this, /api/wildfires falls back to NASA EONET open fire events.
# FIRMS_MAP_KEY=your-map-key-here

# Blitzortung lightning (station operator account — public API retired)
# BLITZORTUNG_USER=your-blitzortung-username
# BLITZORTUNG_PASSWORD=your-blitzortung-password

# GTFS-Realtime (public transit on globe) — Berlin has dedicated VBB feed
# Hamburg/Munich default to gtfs.de aggregate (bbox-filtered per city)
GTFS_BERLIN_URL=https://production.gtfsrt.vbb.de/data
# GTFS_HAMBURG_URL=https://realtime.gtfs.de/realtime-free.pb
# GTFS_MUNICH_URL=https://realtime.gtfs.de/realtime-free.pb
# GTFS_DE_AGGREGATE_URL=https://realtime.gtfs.de/realtime-free.pb
