# Copy this file to .env and fill in your own values.
# Get a free Cesium Ion token at https://ion.cesium.com/tokens
# Required for: World Terrain, OSM 3D Buildings, optional PHOTO 3D (Google Photorealistic Tiles).
# Tip: restrict the token to your domains (URL allowlist) in the Ion console.
# After changing this file, restart the Vite dev server (.\start.ps1). Hard refresh browser (Ctrl+Shift+R).
# If Ion terrain tiles fail (503 in console), the app falls back to flat ellipsoid — see docs/GLOBE.md.
VITE_CESIUM_ION_TOKEN=your_cesium_ion_token_here

# Match backend WORLDBASE_API_KEY when chat returns 401 (local dev only).
# VITE_WORLDBASE_API_KEY=your_api_key_here

# Agent Bus subscriber (globe fly_to / layer toggle from MCP). Match backend WORLDBASE_AGENT_BUS=1.
# VITE_WORLDBASE_AGENT_BUS=1

# Cesium explicit rendering (requestRenderMode): default ON when no pulse layers
# (quakes/nodes/military); OFF while CallbackProperty pulses animate. Override:
# VITE_WORLDBASE_GLOBE_EXPLICIT_RENDER=1 (always on) or =0 (always off).
# VITE_WORLDBASE_GLOBE_EXPLICIT_RENDER=1

# Cesium frame-rate cap (thermal lever): throttle the globe render loop to reduce
# GPU power and heat. Default 30 (smooth for this dashboard; measured ~73% fewer
# Cesium draw-calls vs 60 fps). Raise toward 60 for smoother motion at higher
# power, or set 0 to uncap (browser rAF ~60).
# VITE_WORLDBASE_GLOBE_TARGET_FPS=30

# OpenOSINT on Pi (optional legacy iframe URL; OSINT tab uses built-in tools by default)
VITE_OSINT_URL=http://localhost:15000

# Flowsint graph OSINT (Docker on PC — scripts/setup-flowsint.ps1)
VITE_FLOWSINT_URL=http://localhost:5173

# Optional: ArcGIS Experience URL for S2U / situational map (OSINT → REFERENCE deep-links)
# VITE_S2U_MAP_URL=https://experience.arcgis.com/experience/your-id
