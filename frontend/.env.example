# Copy this file to .env and fill in your own values.
# Get a free Cesium Ion token at https://ion.cesium.com/tokens
# Required for: World Terrain, OSM 3D Buildings, optional PHOTO 3D (Google Photorealistic Tiles).
# Tip: restrict the token to your domains (URL allowlist) in the Ion console.
# After changing this file, restart the Vite dev server (.\start.ps1). Hard refresh browser (Ctrl+Shift+R).
# If Ion terrain tiles fail (503 in console), the app falls back to flat ellipsoid — see docs/GLOBE.md.
VITE_CESIUM_ION_TOKEN=your_cesium_ion_token_here

# Match backend WORLDBASE_API_KEY when chat returns 401 (local dev only).
# VITE_WORLDBASE_API_KEY=your_api_key_here

# Agent Bus subscriber (globe fly_to / layer toggle from MCP). Match backend WORLDBASE_AGENT_BUS=1.
# VITE_WORLDBASE_AGENT_BUS=1

# Cesium explicit rendering (requestRenderMode): default ON — paint only on scene
# change to cut idle CPU/GPU (~25% -> ~3% idle). Pulse rings use throttled
# ConstantProperty updates; Globe.tsx rAF pump calls requestRender() for camera,
# motion layers, pulse ticks, and layer batch refreshes. Opt out for debug:
# VITE_WORLDBASE_GLOBE_CONTINUOUS_RENDER=1

# Legacy alias (no longer required — explicit render is default):
# VITE_WORLDBASE_GLOBE_EXPLICIT_RENDER=1

# Cesium frame-rate cap (thermal lever): throttle the globe render loop to reduce
# GPU power and heat. Default 30 (smooth for this dashboard; caps motion-layer
# repaint cost vs uncapped 60). Raise toward 60 for smoother motion at higher
# power, or set 0 to uncap (browser rAF ~60).
# VITE_WORLDBASE_GLOBE_TARGET_FPS=30

# Retina / HiDPI: Globe.tsx sets useBrowserRecommendedResolution=false and
# resolutionScale=0.5 when devicePixelRatio>1 (FXAA handles edge softening).
# WebGL context uses antialias=false (FXAA post-process remains on).

# Render-quiescence idle fps (extra heat lever, default OFF). The globe's tilesLoaded
# never turns true (off-screen preload tiles never settle), so it repaints at the full
# capped rate even when the visible scene is static. When set, Globe.tsx drops the
# render loop to this fps once the visible scene is provably idle (visible tiles
# loaded, camera still, no motion/pulse layer, no tracked entity/focus) and restores
# instantly on interaction. Same quality (only a static visible scene is throttled);
# measured 30 -> 2 fps cut idle draws ~1,828/s -> ~121/s (~93%). Try 2; unset/<=0 = off.
# VITE_WORLDBASE_GLOBE_IDLE_FPS=2

# Globe tile detail (maximumScreenSpaceError). Cesium default is 2.0; lower loads
# more tiles (~4× cost at 1.0). Default in Globe.tsx is now 2.0. While panning or
# above 100 km altitude, SSE is raised automatically (4.0 / 3.0) to cut tile churn.
# VITE_WORLDBASE_GLOBE_SSE=2

# Globe imagery tile RAM cache (default 100). Raise for fewer re-loads on fast pan/zoom
# when using requestRenderMode (e.g. 500–1000 on 16 GB+ machines).
# VITE_WORLDBASE_GLOBE_TILE_CACHE=500

# OpenOSINT on Pi (optional legacy iframe URL; OSINT tab uses built-in tools by default)
VITE_OSINT_URL=http://localhost:15000

# Flowsint graph OSINT (Docker on PC — scripts/setup-flowsint.ps1)
VITE_FLOWSINT_URL=http://localhost:5173

# Optional: ArcGIS Experience URL for S2U / situational map (OSINT → REFERENCE deep-links)
# VITE_S2U_MAP_URL=https://experience.arcgis.com/experience/your-id
