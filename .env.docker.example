# Root .env consumed by docker-compose.yml. Copy to .env (git-ignored) or let
# scripts/start-docker.ps1 generate it automatically.

# Cesium Ion token — baked into the frontend build (globe terrain/imagery).
VITE_CESIUM_ION_TOKEN=

# PC LAN IP that Caddy issues an internal TLS cert for, so the Pi can reach
# https://<this-ip>/api/node/ingest. Leave as loopback for PC-only use.
WORLDBASE_LAN=127.0.0.1

# Extra browser origin(s) allowed by the API (comma-separated). Usually the
# HTTPS LAN origin, e.g. https://192.168.1.111
WORLDBASE_CORS_ORIGINS=

# Secure-by-default: 1 = backend refuses to start LAN-exposed without a token.
WORLDBASE_REQUIRE_NODE_TOKEN=1

# Reach the host's Ollama from inside the backend container.
OLLAMA_HOST=host.docker.internal:11434

# Flowsint UI (optional; only if you run the Flowsint docker stack).
VITE_FLOWSINT_URL=http://localhost:5173
